# ─────────────────────────────────────────────────────────────
# Supabase — copia questo file in `.env.local` e inserisci i valori
# del tuo progetto (Project Settings → API).
# ─────────────────────────────────────────────────────────────

# URL pubblico del progetto Supabase (es. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Chiave pubblica "anon" (sicura da esporre lato client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chiave "service_role" — USARE SOLO lato server (mai esporre al client).
# Necessaria per lo script di seed e per le operazioni admin server-side.
SUPABASE_SERVICE_ROLE_KEY=
